        function renderFlashcard() {
            const card = flashcardsDataset[currentFlashcardIndex];
            document.getElementById('flash-category').innerText = card.cat;
            document.getElementById('flash-front-text').innerText = card.front;
            document.getElementById('flash-back-text').innerText = card.back;
            
            const cardEl = document.querySelector('.flashcard');
            cardEl.classList.remove('flipped');
            if (ttsEnabled) {
                speakCurrentFlashcard();
            }
        }

        function flipFlashcard(element) {
            element.classList.toggle('flipped');
        }

        function nextFlashcard() {
            currentFlashcardIndex = (currentFlashcardIndex + 1) % flashcardsDataset.length;
            renderFlashcard();
        }

        function prevFlashcard() {
            currentFlashcardIndex = (currentFlashcardIndex - 1 + flashcardsDataset.length) % flashcardsDataset.length;
            renderFlashcard();
        }

        function loadQuizQuestion() {
            if (examQuestions.length === 0) return;
            const q = examQuestions[currentQuestionIndex];
            
            document.getElementById('engine-question-counter').innerText = `Soru: ${currentQuestionIndex + 1} / ${examQuestions.length}`;
            document.getElementById('engine-question-category').innerText = q.cat;
            document.getElementById('engine-progress').style.width = `${((currentQuestionIndex + 1) / examQuestions.length) * 100}%`;
            document.getElementById('question-text').innerText = q.q;

            updateModeBadge();
            updatePracticeStatsUI();

            const isBookmarked = bookmarkedQuestions.includes(q.q);
            const favBtn = document.getElementById('btn-favorite');
            if (isBookmarked) {
                favBtn.className = "p-2.5 rounded-xl border border-accent-amber/30 bg-accent-amber/10 hover:bg-accent-amber/20 transition-colors text-accent-amber";
            } else {
                favBtn.className = "p-2.5 rounded-xl border border-slate-600 hover:bg-slate-700 transition-colors text-slate-400";
            }

            const optionsGrid = document.getElementById('engine-options-grid');
            optionsGrid.innerHTML = '';

            const explanationContainer = document.getElementById('explanation-container');
            explanationContainer.classList.add('hidden');
            document.getElementById('study-link-container').classList.add('hidden');

            q.a.forEach((option, idx) => {
                const btn = document.createElement('button');
                btn.className = `btn-option w-full p-4 rounded-2xl text-left font-semibold flex items-start text-xs sm:text-sm`;
                
                const isSelected = selectedAnswers[currentQuestionIndex] === idx;
                if (isSelected) {
                    btn.classList.add('selected');
                }

                if (studyMode === 'practice' && selectedAnswers[currentQuestionIndex] !== undefined) {
                    if (idx === q.c) {
                        btn.className = `btn-option w-full p-4 rounded-2xl text-left font-semibold flex items-start text-xs sm:text-sm correct-flash text-white`;
                    } else if (isSelected) {
                        btn.className = `btn-option w-full p-4 rounded-2xl text-left font-semibold flex items-start text-xs sm:text-sm wrong-flash text-white`;
                    }
                    explanationContainer.classList.remove('hidden');
                    document.getElementById('explanation-text').innerText = q.explanation;
                }

                btn.innerHTML = `
                    <span class="mr-3 font-black text-brand-300 bg-brand-500/20 w-6 h-6 rounded-lg flex items-center justify-center text-[10px] flex-shrink-0 ${isSelected ? 'text-slate-900 bg-brand-400' : ''}">${String.fromCharCode(65 + idx)}</span>
                    <span class="flex-grow">${option}</span>
                `;

                btn.onclick = () => {
                    if (studyMode === 'practice' && selectedAnswers[currentQuestionIndex] !== undefined) {
                        return; 
                    }
                    selectQuizAnswer(idx);
                };

                optionsGrid.appendChild(btn);
            });

            document.getElementById('engine-prev-btn').disabled = currentQuestionIndex === 0;
            if (currentQuestionIndex === examQuestions.length - 1) {
                document.getElementById('engine-next-btn').classList.add('hidden');
                document.getElementById('engine-finish-btn').classList.remove('hidden');
            } else {
                document.getElementById('engine-next-btn').classList.remove('hidden');
                document.getElementById('engine-finish-btn').classList.add('hidden');
            }
        }

        function selectQuizAnswer(answerIndex) {
            selectedAnswers[currentQuestionIndex] = answerIndex;
            updateGlobalStats();
            
            const q = examQuestions[currentQuestionIndex];
            const isCorrect = answerIndex === q.c;
            
            // Track attempt history per question
            if (!attemptHistory[currentQuestionIndex]) {
                attemptHistory[currentQuestionIndex] = { attempts: 0, wrongCount: 0 };
            }
            attemptHistory[currentQuestionIndex].attempts++;
            if (!isCorrect) {
                attemptHistory[currentQuestionIndex].wrongCount++;
            }
            localStorage.setItem('attempt_history_tr102', JSON.stringify(attemptHistory));
            
            if (studyMode === 'practice') {
                practiceSessionStats.attempted++;
                if (isCorrect) {
                    practiceSessionStats.correct++;
                    showNotification("✅ Doğru cevap!", "success");
                    speakText("Tebrikler, doğru cevap.");
                } else {
                    practiceSessionStats.wrong++;
                    showNotification("❌ Yanlış cevap. Yanlış Bankası'na eklendi.", "amber");
                    speakText("Maalesef yanlış cevap.");
                }
                updatePracticeStatsUI();
            }
            
            loadQuizQuestion();
        }

        function engineNextQuestion() {
            stopAutoAdvance();
            if (currentQuestionIndex < examQuestions.length - 1) {
                currentQuestionIndex++;
                loadQuizQuestion();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else if (studyMode === 'practice') {
                finishPracticeSession();
            }
        }

        function enginePrevQuestion() {
            stopAutoAdvance();
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                loadQuizQuestion();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        function toggleFavoriteCurrentQuestion() {
            const q = examQuestions[currentQuestionIndex];
            const idx = bookmarkedQuestions.indexOf(q.q);
            if (idx > -1) {
                bookmarkedQuestions.splice(idx, 1);
                showNotification("Soru favorilerden kaldırıldı.");
            } else {
                bookmarkedQuestions.push(q.q);
                showNotification("Soru favorilere eklendi!", "success");
            }
            localStorage.setItem('bookmarked_questions_tr2', JSON.stringify(bookmarkedQuestions));
            updateGlobalStats();
            loadQuizQuestion();
            renderLibrary();
        }

        function finishExamAndShowAnalytics() {
            stopAutoAdvance();
            document.getElementById('active-quiz-box').classList.add('hidden');
            document.getElementById('results-analytics-box').classList.remove('hidden');

            let correctCount = 0;
            const categoryPerformances = {};

            examQuestions.forEach((q, idx) => {
                if (!categoryPerformances[q.cat]) {
                    categoryPerformances[q.cat] = { correct: 0, total: 0 };
                }
                categoryPerformances[q.cat].total++;

                if (selectedAnswers[idx] === q.c) {
                    correctCount++;
                    categoryPerformances[q.cat].correct++;
                }
            });

            const totalCount = examQuestions.length;
            const scorePercentage = Math.round((correctCount / totalCount) * 100);

            document.getElementById('final-score-big').innerText = `${correctCount} / ${totalCount}`;

            let letterGrade = 'FF';
            let feedback = '';
            if (scorePercentage >= 90) { letterGrade = 'AA'; feedback = 'Olağanüstü! TRK102 müfredatının tam ustasısın. Dil açıklarını kapatmışsın!'; }
            else if (scorePercentage >= 80) { letterGrade = 'BA'; feedback = 'Harika! Birkaç dikkatsizlik dışında tüm kavramlara hakimsin.'; }
            else if (scorePercentage >= 70) { letterGrade = 'BB'; feedback = 'Çok İyi! Final sınavında rahatlıkla AA alabilecek bir performans.'; }
            else if (scorePercentage >= 60) { letterGrade = 'CB'; feedback = 'Başarılı! Yazım ve resmi belgeler kurallarına biraz daha çalışmalısın.'; }
            else if (scorePercentage >= 50) { letterGrade = 'CC'; feedback = 'Geçer seviyedir. Dil açıklarını kapatmak için Hızlı Özet alanını oku.'; }
            else { letterGrade = 'FF'; feedback = 'Eksiklerin bulunuyor. Panik yapma, Hap Bilgi alanından TRK101 eksik kapatma formüllerini çalış.'; }

            document.getElementById('letter-grade-badge').innerText = letterGrade;
            document.getElementById('final-feedback-text').innerText = feedback;

            renderAnalyticsCharts(correctCount, totalCount - correctCount, categoryPerformances);
            generateAIStudyRecommendations(categoryPerformances);
            window.scrollTo({ top: 0, behavior: 'smooth' });

            // Confetti celebration if good score
            if (scorePercentage >= 50) {
                fireConfetti();
            }
        }

        // Confetti celebration
        function fireConfetti() {
            const colors = ['#818cf8', '#10b981', '#f59e0b', '#f43f5e', '#06b6d4', '#a78bfa'];
            for (let i = 0; i < 60; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.left = Math.random() * 100 + 'vw';
                piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                piece.style.width = (Math.random() * 8 + 4) + 'px';
                piece.style.height = (Math.random() * 8 + 4) + 'px';
                piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                piece.style.animationDuration = (Math.random() * 2 + 2) + 's';
                piece.style.animationDelay = (Math.random() * 2) + 's';
                document.body.appendChild(piece);
                setTimeout(() => piece.remove(), 4000);
            }
        }

        function renderAnalyticsCharts(correct, wrong, catStats) {
            const pieCtx = document.getElementById('chart-pie-success').getContext('2d');
            new Chart(pieCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Doğru', 'Yanlış / Boş'],
                    datasets: [{
                        data: [correct, wrong],
                        backgroundColor: ['#10b981', '#f43f5e'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            const barCtx = document.getElementById('chart-bar-topics').getContext('2d');
            const labels = Object.keys(catStats);
            const data = labels.map(lbl => Math.round((catStats[lbl].correct / catStats[lbl].total) * 100));

            new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Konu Başarısı (%)',
                        data: data,
                        backgroundColor: '#0284c7',
                        borderRadius: 12
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, max: 100 }
                    }
                }
            });
        }

        function generateAIStudyRecommendations(catStats) {
            const recommenderList = document.getElementById('ai-recommender-list');
            recommenderList.innerHTML = '';

            let recommendationAdded = false;

            Object.keys(catStats).forEach(cat => {
                const ratio = catStats[cat].correct / catStats[cat].total;
                if (ratio < 0.6) {
                    recommendationAdded = true;
                    const alertDiv = document.createElement('div');
                    alertDiv.className = 'p-4 bg-amber-500/10 text-amber-200 border border-amber-500/20 rounded-2xl flex items-start space-x-3';
                    alertDiv.innerHTML = `
                        <span class="text-xl mt-0.5">⚠️</span>
                        <div>
                            <h5 class="font-bold">${cat} Eksik Bölgesi!</h5>
                            <p class="text-xs text-amber-300 mt-1">Bu alandaki başarı yüzden %${Math.round(ratio*100)} seviyesinde kaldı. Yazışma dillerinde hata yapmamak adına, "Hap Özet" sekmesindeki ilgili başlıkları mutlaka oku.</p>
                        </div>
                    `;
                    recommenderList.appendChild(alertDiv);
                }
            });

            if (!recommendationAdded) {
                const successDiv = document.createElement('div');
                successDiv.className = 'p-4 bg-accent-emerald/10 text-accent-emerald border border-accent-emerald/20 rounded-2xl flex items-start space-x-3';
                successDiv.innerHTML = `
                    <span class="text-xl mt-0.5">✨</span>
                    <div>
                        <h5 class="font-bold">Eksiksiz Performans!</h5>
                        <p class="text-xs text-emerald-300 mt-1">TRK102 ve TRK101 alt yapı kurallarına tamamen hakim görünüyorsun. Sınava hazırsın!</p>
                    </div>
                `;
                recommenderList.appendChild(successDiv);
            }
        }

