<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#f8fafc">
    <meta name="mobile-web-app-capable" content="yes">
    <title>Türk Dili II - Premium Ultimate Final Akademisi</title>
    
    <!-- Tailwind CSS ve Chart.js -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Google Fonts ve Stil Tanımları -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;0,800;1,700&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe',
                            500: '#6366f1', 600: '#4f46e5', 700: '#4338ca', 900: '#312e81'
                        },
                        accent: {
                            emerald: '#10b981', amber: '#f59e0b', rose: '#f43f5e',
                            indigo: '#6366f1', violet: '#8b5cf6', cyan: '#06b6d4'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    animation: {
                        'glow': 'glow 2s ease-in-out infinite alternate',
                        'float': 'float 3s ease-in-out infinite',
                        'pulse-soft': 'pulseSoft 2s ease-in-out infinite',
                        'slide-up': 'slideUp 0.4s ease-out',
                        'scale-in': 'scaleIn 0.3s ease-out'
                    },
                    keyframes: {
                        glow: {
                            '0%': { boxShadow: '0 0 5px rgba(99,102,241,0.2), 0 0 10px rgba(99,102,241,0.1)' },
                            '100%': { boxShadow: '0 0 20px rgba(99,102,241,0.4), 0 0 40px rgba(99,102,241,0.2)' }
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-6px)' }
                        },
                        pulseSoft: {
                            '0%, 100%': { opacity: '1' },
                            '50%': { opacity: '0.7' }
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' }
                        },
                        scaleIn: {
                            '0%': { transform: 'scale(0.95)', opacity: '0' },
                            '100%': { transform: 'scale(1)', opacity: '1' }
                        }
                    }
                }
            }
        }
    </script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
            -webkit-tap-highlight-color: transparent;
            overscroll-behavior-y: none;
            color: #e2e8f0;
        }

        .premium-glass {
            background: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(99, 102, 241, 0.15);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        
        .premium-glass-light {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .interactive-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(99, 102, 241, 0.1);
            border-radius: 1rem;
        }
        .interactive-card:hover {
            transform: translateY(-3px);
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 20px 40px rgba(99, 102, 241, 0.08);
        }

        .btn-option {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            border: 2px solid rgba(99, 102, 241, 0.15);
            background: rgba(30, 41, 59, 0.3);
            color: #cbd5e1;
            min-height: 48px;
        }
        .btn-option:hover {
            border-color: rgba(99, 102, 241, 0.4);
            background: rgba(99, 102, 241, 0.08);
            transform: translateX(4px);
        }
        .btn-option.selected {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: white;
            border-color: #4f46e5;
            box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.3);
        }
        .btn-option.correct-flash {
            background: linear-gradient(135deg, #10b981, #059669) !important;
            color: white !important;
            border-color: #059669 !important;
            box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.3) !important;
        }
        .btn-option.wrong-flash {
            background: linear-gradient(135deg, #f43f5e, #e11d48) !important;
            color: white !important;
            border-color: #e11d48 !important;
            box-shadow: 0 10px 25px -5px rgba(244, 63, 94, 0.3) !important;
            animation: shake 0.4s ease-in-out;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-4px); }
            80% { transform: translateX(4px); }
        }

        @keyframes confetti-fall {
            0% { transform: translateY(-10px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100px) rotate(720deg); opacity: 0; }
        }

        .confetti-piece {
            animation: confetti-fall 1.5s ease-in forwards;
        }

        /* Flashcard Flip Animasyon Yapısı */
        .flashcard-inner {
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            transform-style: preserve-3d;
        }
        .flashcard.flipped .flashcard-inner {
            transform: rotateY(180deg);
        }
        .flashcard-front, .flashcard-back {
            backface-visibility: hidden;
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            border-radius: 1rem;
        }
        .flashcard-front {
            background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.05));
            border: 1px solid rgba(99,102,241,0.2);
        }
        .flashcard-back {
            transform: rotateY(180deg);
            background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(6,182,212,0.05));
            border: 1px solid rgba(16,185,129,0.2);
        }

        /* Dil Laboratuvarı Hata İşaretlemeleri */
        .err-highlight {
            background-color: rgba(244, 63, 94, 0.15);
            border-bottom: 2px dashed #f43f5e;
            color: #fca5a5;
            padding: 0 4px;
            font-weight: 600;
            cursor: help;
            border-radius: 2px;
        }

        /* Mobil Cihaz Çentik ve Navigasyon Boşlukları */
        .pb-safe { padding-bottom: calc(env(safe-area-inset-bottom, 16px) + 96px); }
        .pt-safe { padding-top: env(safe-area-inset-top, 0px); }

        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
            -moz-text-size-adjust: 100%;
        }

        @media (max-width: 640px) {
            .pb-safe { padding-bottom: calc(env(safe-area-inset-bottom, 16px) + 80px); }
        }

        /* iOS/Android Touch Improvements */
        * {
            -webkit-tap-highlight-color: transparent;
            tap-highlight-color: transparent;
        }
        button, a, .btn-option, .nav-item, .interactive-card {
            cursor: pointer;
            touch-action: manipulation;
        }
        .nav-item {
            -webkit-tap-highlight-color: transparent;
            min-width: 48px;
            min-height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        /* iOS Scroll Fix */
        .tab-content, .summary-content, #lab-errors-list, #lab-editor {
            -webkit-overflow-scrolling: touch;
        }
        .summary-content {
            max-height: none;
            overflow-y: visible;
        }
        /* Prevent text size adjustment on orientation change */
        html {
            -webkit-text-size-adjust: 100%;
        }
        /* Better touch feedback */
        .btn-option:active:not(.selected):not(.correct-flash):not(.wrong-flash) {
            transform: scale(0.98);
        }
        button:active, .nav-item:active {
            opacity: 0.8;
        }

        /* Fixed bottom nav - ensure content scrolls above it */
        nav.fixed {
            pointer-events: auto;
        }
        main {
            flex: 1 0 auto;
            width: 100%;
        }
        .tab-content {
            width: 100%;
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: rgba(30, 41, 59, 0.3); }
        ::-webkit-scrollbar-thumb { background: rgba(99, 102, 241, 0.3); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(99, 102, 241, 0.5); }

        /* Glow border effect */
        .glow-border {
            position: relative;
        }
        .glow-border::after {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: inherit;
            background: linear-gradient(135deg, rgba(99,102,241,0.3), rgba(139,92,246,0.1), rgba(99,102,241,0.3));
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .glow-border:hover::after {
            opacity: 1;
        }

        .gradient-text {
            background: linear-gradient(135deg, #818cf8, #a78bfa, #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .cat-test-btn {
            transition: all 0.3s ease;
        }
        .cat-test-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.15);
        }

        .hint-box {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease, opacity 0.3s ease, margin 0.3s ease;
            opacity: 0;
            margin-top: 0;
        }
        .hint-box.active {
            max-height: 200px;
            opacity: 1;
            margin-top: 12px;
        }

        /* Stats card hover glow */
        .stat-glow {
            transition: all 0.3s ease;
        }
        .stat-glow:hover {
            box-shadow: 0 0 30px rgba(99,102,241,0.1);
            border-color: rgba(99,102,241,0.3);
            transform: translateY(-2px);
        }

        .nav-item.active {
            color: #818cf8 !important;
        }
        .nav-item.active svg {
            stroke: #818cf8;
        }

        /* Premium glass card base */
        .premium-card {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(99, 102, 241, 0.1);
            transition: all 0.3s ease;
        }
        .premium-card:hover {
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.08);
        }

        .premium-glass {
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(16px);
        }

        /* Feedback banners */
        .feedback-correct {
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-left: 4px solid #10b981;
        }
        .feedback-wrong {
            background: rgba(244, 63, 94, 0.15);
            border: 1px solid rgba(244, 63, 94, 0.3);
            border-left: 4px solid #f43f5e;
        }

        /* Confetti */
        .confetti-piece {
            position: fixed;
            width: 8px;
            height: 8px;
            z-index: 9999;
            pointer-events: none;
            animation: confettiFall linear forwards;
        }
        @keyframes confettiFall {
            0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col pt-safe pb-safe bg-slate-900 text-slate-100 overflow-x-hidden">

    <header class="sticky top-0 z-40 premium-glass border-b border-brand-500/10 shadow-lg shadow-brand-500/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-brand-500 to-accent-violet flex items-center justify-center text-white font-black shadow-lg shadow-brand-500/30 animate-glow">
                    TR2
                </div>
                <div>
                    <h1 class="text-base sm:text-lg font-black tracking-tight gradient-text">Türk Dili II (TRK102)</h1>
                    <p class="text-[9px] font-bold text-slate-500 tracking-widest uppercase">Ultimate Final Akademisi</p>
                </div>
            </div>
            
            <div class="flex items-center space-x-3">
                <button id="btn-tts-global" onclick="toggleSpeechGlobally()" class="p-2.5 rounded-xl border border-brand-500/20 hover:bg-brand-500/10 transition-all text-slate-400 hover:text-brand-400" title="Sesli Okumayı Etkinleştir">
                    <svg id="tts-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path></svg>
                </button>
                <div class="hidden sm:flex bg-slate-800/50 p-1 rounded-xl border border-brand-500/10 text-xs font-semibold">
                    <button onclick="setGlobalStudyMode('quiz')" id="mode-quiz" class="px-3 py-1.5 rounded-lg transition-all bg-brand-500/20 text-white shadow-sm">Simülasyon</button>
                    <button onclick="setGlobalStudyMode('practice')" id="mode-practice" class="px-3 py-1.5 rounded-lg transition-all text-slate-400 hover:text-white">Çözüm Odaklı</button>
                </div>
            </div>
        </div>
    </header>

    <div id="speech-control-bar" class="fixed bottom-24 right-4 z-50 hidden bg-slate-900 text-white px-4 py-2.5 rounded-2xl shadow-xl flex items-center space-x-3 border border-slate-800 animate-bounce">
        <span class="w-2.5 h-2.5 bg-brand-500 rounded-full animate-ping"></span>
        <span class="text-xs font-bold text-slate-300">Akıllı Ses Motoru</span>
        <div class="flex items-center space-x-1.5 border-l border-slate-700 pl-3">
            <button onclick="pauseSpeech()" class="p-1 hover:text-brand-400 transition-colors" title="Duraklat"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg></button>
            <button onclick="resumeSpeech()" class="p-1 hover:text-brand-400 transition-colors" title="Devam Et"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg></button>
            <button onclick="stopSpeech()" class="p-1 hover:text-accent-rose transition-colors" title="Sustur"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8 7a1 1 0 00-1 1v4a1 1 0 001 1h4a1 1 0 001-1V8a1 1 0 00-1-1H8z" clip-rule="evenodd"></path></svg></button>
        </div>
    </div>

    <div id="toast-container" class="fixed top-20 right-4 z-50 pointer-events-none flex flex-col space-y-2"></div>

    <main class="flex-grow max-w-4xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <!-- ================= TAB 1: DASHBOARD ================= -->
        <div id="tab-dashboard" class="tab-content space-y-6">
            <!-- Görsel Tasarım ve Karşılama Paneli -->
            <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-indigo-950 via-slate-800 to-brand-900 text-white p-6 sm:p-8 shadow-2xl border border-brand-500/10">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(99,102,241,0.2),transparent_50%)]"></div>
                <div class="absolute top-0 right-0 w-64 h-64 bg-brand-500/5 rounded-full blur-3xl"></div>
                <div class="relative z-10 max-w-xl">
                    <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold tracking-wider bg-brand-500/20 text-brand-300 border border-brand-500/20 uppercase mb-4">Türk Dili II Final Üssü</span>
                    <h2 class="text-2xl sm:text-3xl font-extrabold font-serif leading-tight gradient-text">Mükemmel Sınav Başarısı & Profesyonel Yazım Akademisi</h2>
                    <p class="mt-2 text-slate-300 text-xs sm:text-sm leading-relaxed">TRK102 sınavındaki 50 seçkin sorunun tamamı, akademik çözümlemeleri ve Türk Dili I'den gelen yazım-noktalama açıklarını tamamen sıfırlayan akıllı öğrenme kiti.</p>
                    <div class="mt-6 flex flex-wrap gap-3">
                        <button onclick="switchTab('quiz-engine')" class="bg-brand-500 hover:bg-brand-400 text-white font-black px-6 py-3 rounded-2xl shadow-lg shadow-brand-500/30 transition-all text-xs hover:scale-105 active:scale-95">Akademik Simülasyon</button>
                        <button onclick="switchTab('summary')" class="bg-white/5 hover:bg-white/10 border border-white/10 font-semibold px-6 py-3 rounded-2xl transition-all text-xs">15 Adımda Eğitim Özetleri</button>
                    </div>
                    <div class="mt-6 pt-4 border-t border-brand-500/10 flex items-center justify-between text-[10px] text-slate-500">
                        <span class="font-semibold tracking-wider">🚀 <span class="text-brand-400">TRK102</span> Ultimate Final Akademisi</span>
                        <span class="font-medium">Hazırlayan: <span class="text-accent-amber font-bold">Metebey</span> &amp; <span class="text-accent-amber font-bold">Mrs. Görkem</span> ✨</span>
                    </div>
                </div>
            </section>

            <section class="grid grid-cols-2 sm:grid-cols-5 gap-3">
                <div class="premium-card p-4 rounded-2xl flex flex-col items-center justify-center text-center">
                    <span class="text-xl sm:text-2xl font-black text-brand-400">50</span>
                    <span class="text-[10px] font-bold text-slate-500 mt-1">Soru Portföyü</span>
                </div>
                <div class="premium-card p-4 rounded-2xl flex flex-col items-center justify-center text-center">
                    <span id="stat-completed" class="text-xl sm:text-2xl font-black text-accent-emerald">0%</span>
                    <span class="text-[10px] font-bold text-slate-500 mt-1">İlerleme Oranı</span>
                </div>
                <div id="metric-favorites" class="premium-card p-4 rounded-2xl flex flex-col items-center justify-center text-center cursor-pointer stat-glow" onclick="switchTab('library')">
                    <span id="stat-favorites-count" class="text-xl sm:text-2xl font-black text-accent-amber">0</span>
                    <span class="text-[10px] font-bold text-slate-500 mt-1">Yıldızlı Soru</span>
                </div>
                <div id="metric-wrongbank" class="premium-card p-4 rounded-2xl flex flex-col items-center justify-center text-center cursor-pointer stat-glow" onclick="openWrongAnswerBank()">
                    <span id="stat-wrong-count" class="text-xl sm:text-2xl font-black text-accent-rose">0</span>
                    <span class="text-[10px] font-bold text-slate-500 mt-1">Yanlış Bankası</span>
                </div>
                <div id="metric-quest" class="premium-card p-4 rounded-2xl flex flex-col items-center justify-center text-center cursor-pointer stat-glow" onclick="openMiniExam()">
                    <span class="text-xl sm:text-2xl font-black text-accent-cyan">Meydan</span>
                    <span class="text-[10px] font-bold text-slate-500 mt-1">Mini Sınav 🎯</span>
                </div>
            </section>

            <section class="bg-slate-800/50 rounded-3xl p-6 border border-slate-700/50 shadow-sm space-y-4 backdrop-blur-sm">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-base font-extrabold text-slate-100">Ustalık Hafıza Kartları</h3>
                        <p class="text-[11px] text-slate-500">Üzerine dokunarak kartı çevirebilirsin. TTS etkinken otomatik olarak okunur.</p>
                    </div>
                    <div class="flex space-x-2">
                        <button onclick="speakCurrentFlashcard()" class="p-2 rounded-xl bg-slate-700/50 hover:bg-slate-700 border border-slate-600 text-slate-400 transition-all" title="Kartı Seslendir">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path></svg>
                        </button>
                        <button onclick="prevFlashcard()" class="p-2 rounded-xl bg-slate-700/50 hover:bg-slate-700 border border-slate-600 text-slate-400 transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </button>
                        <button onclick="nextFlashcard()" class="p-2 rounded-xl bg-slate-700/50 hover:bg-slate-700 border border-slate-600 text-slate-400 transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>

                <div class="flashcard w-full h-44 relative cursor-pointer" onclick="flipFlashcard(this)">
                    <div class="flashcard-inner absolute w-full h-full text-center transition-transform duration-500 shadow-sm rounded-2xl">
                        <div class="flashcard-front bg-gradient-to-br from-slate-800 to-slate-700 border border-brand-500/20 p-6 rounded-2xl flex flex-col items-center justify-center h-full">
                            <span class="text-[10px] font-bold text-brand-400 uppercase tracking-widest mb-2" id="flash-category">Kategori</span>
                            <h4 class="text-sm sm:text-base font-extrabold text-slate-100" id="flash-front-text">Yükleniyor...</h4>
