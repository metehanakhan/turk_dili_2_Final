    <script>
        // Global Durum Değişkenleri
        let currentTab = 'dashboard';
        let examQuestions = [];
        let currentQuestionIndex = 0;
        let selectedAnswers = {}; 
        let bookmarkedQuestions = JSON.parse(localStorage.getItem('bookmarked_questions_tr2')) || [];
        let currentFlashcardIndex = 0;
        let studyMode = 'quiz'; 
        let practiceSessionStats = { attempted: 0, correct: 0, wrong: 0 };
        let attemptHistory = JSON.parse(localStorage.getItem('attempt_history_tr102')) || {};
        let autoAdvanceTimer = null;
        let ttsEnabled = false;
        let activeUtterance = null;

        window.onload = function() {
            initApp();
            analyzeLabText(); 
        };

        function initApp() {
            examQuestions = [...questionsDataset];
            renderFlashcard();
            renderLibrary();
            updateGlobalStats();
            
            if (!('speechSynthesis' in window)) {
                document.getElementById('btn-tts-global').style.display = 'none';
                document.getElementById('btn-tts-speak').style.display = 'none';
            }
        }

        // Sekme Değiştirici
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.nav-item').forEach(el => {
                el.classList.remove('text-brand-400');
                el.classList.add('text-slate-500');
            });

            const targetTab = document.getElementById(`tab-${tabId}`);
            if (targetTab) targetTab.classList.remove('hidden');

            const targetNav = document.getElementById(`nav-${tabId}`);
            if (targetNav) {
                targetNav.classList.remove('text-slate-500');
                targetNav.classList.add('text-brand-400');
            }

            currentTab = tabId;
            window.scrollTo({ top: 0, behavior: 'smooth' });

            if (tabId === 'quiz-engine') {
                loadQuizQuestion();
            } else if (tabId === 'proofreader-lab') {
                analyzeLabText();
            }
            // Reset hint
            const hintBox = document.getElementById('hint-box');
            if (hintBox) hintBox.classList.remove('active');
            const hintBtn = document.getElementById('btn-hint');
            if (hintBtn) hintBtn.querySelector('span').textContent = 'İpucu Göster';

            stopSpeech(); 
        }

        // Bildirim Sistemi (Toast)
        function showNotification(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `p-4 rounded-xl shadow-lg text-xs font-bold pointer-events-auto transition-all duration-300 transform translate-x-10 opacity-0 flex items-center space-x-2`;
            
            if (type === 'success') {
                toast.className += ' bg-emerald-500 text-white';
            } else if (type === 'amber') {
                toast.className += ' bg-amber-500 text-white';
            } else {
                toast.className += ' bg-slate-800 text-white';
            }

            toast.innerHTML = `<span>${message}</span>`;
            container.appendChild(toast);

            setTimeout(() => {
                toast.classList.remove('translate-x-10', 'opacity-0');
            }, 50);

            setTimeout(() => {
                toast.classList.add('translate-x-10', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 2500);
        }

        function updateGlobalStats() {
            const completedCount = Object.keys(selectedAnswers).length;
            const percentage = Math.round((completedCount / examQuestions.length) * 100);
            document.getElementById('stat-completed').innerText = `${percentage}%`;
            document.getElementById('stat-favorites-count').innerText = bookmarkedQuestions.length;
        }

        function updateModeBadge() {
            const badge = document.getElementById('mode-badge');
            const statsBar = document.getElementById('practice-stats-bar');
            if (!badge) return;
            if (studyMode === 'practice') {
                badge.className = 'inline-block text-[9px] font-black uppercase tracking-widest px-2 py-1 rounded-full bg-accent-amber/20 text-accent-amber border border-accent-amber/30';
                badge.textContent = '🎯 Çözüm Odaklı';
                badge.classList.remove('hidden');
                if (statsBar) statsBar.classList.remove('hidden');
            } else {
                badge.className = 'inline-block text-[9px] font-black uppercase tracking-widest px-2 py-1 rounded-full bg-brand-500/20 text-brand-300 border border-brand-500/30';
                badge.textContent = '📝 Sınav Modu';
                badge.classList.remove('hidden');
                if (statsBar) statsBar.classList.add('hidden');
            }
        }

        function updatePracticeStatsUI() {
            const total = practiceSessionStats.attempted;
            const correct = practiceSessionStats.correct;
            const wrong = practiceSessionStats.wrong;
            const acc = total > 0 ? Math.round((correct / total) * 100) : 0;
            document.getElementById('ps-attempted').textContent = total;
            document.getElementById('ps-correct').textContent = correct;
            document.getElementById('ps-wrong').textContent = wrong;
            document.getElementById('ps-accuracy').textContent = total > 0 ? `%${acc}` : '-%';
        }

        function stopAutoAdvance() {
            if (autoAdvanceTimer) {
                clearTimeout(autoAdvanceTimer);
                autoAdvanceTimer = null;
            }
            const indicator = document.getElementById('auto-advance-indicator');
            if (indicator) indicator.classList.add('hidden');
        }

        function startAutoAdvance() {
            stopAutoAdvance();
            if (studyMode !== 'practice') return;
            const indicator = document.getElementById('auto-advance-indicator');
            if (!indicator) return;
            indicator.classList.remove('hidden');
            let countdown = 3;
            indicator.textContent = `⏳ ${countdown} sn sonra geçiyorum...`;
            const interval = setInterval(() => {
                countdown--;
                if (countdown > 0) {
                    indicator.textContent = `⏳ ${countdown} sn sonra geçiyorum...`;
                } else {
                    clearInterval(interval);
                    indicator.textContent = '⏩ Geçiyorum!';
                }
            }, 1000);
            autoAdvanceTimer = setTimeout(() => {
                stopAutoAdvance();
                if (currentQuestionIndex < examQuestions.length - 1) {
                    engineNextQuestion();
                } else {
                    finishPracticeSession();
                }
            }, 3500);
        }

        function navigateToStudyTopic() {
            const q = examQuestions[currentQuestionIndex];
            if (!q) return;
            const cat = q.cat || '';
            // Find matching summary section
            const summarySections = document.querySelectorAll('#tab-summary .summary-section');
            let targetSection = null;
            summarySections.forEach(sec => {
                const title = (sec.getAttribute('data-title') || '').toLowerCase();
                const catLower = cat.toLowerCase();
                if (catLower.includes('paragraf') && (title.includes('paragraf') || title.includes('kompozisyon'))) targetSection = sec;
                if (catLower.includes('sözlü') && title.includes('konuşma')) targetSection = sec;
                if (catLower.includes('yazım') && title.includes('yazım')) targetSection = sec;
                if (catLower.includes('noktalama') && title.includes('noktalama')) targetSection = sec;
                if (catLower.includes('anlatım') && (title.includes('anlatım') || title.includes('biçem'))) targetSection = sec;
                if (catLower.includes('dil') && title.includes('dil')) targetSection = sec;
                if (catLower.includes('kültür') && title.includes('kültür')) targetSection = sec;
                if (catLower.includes('bilgi') && title.includes('bilgi')) targetSection = sec;
                if (catLower.includes('edebi') && (title.includes('edebi') || title.includes('tiyatro') || title.includes('masal'))) targetSection = sec;
                if (catLower.includes('yazı') && (title.includes('yazı') || title.includes('makale') || title.includes('gazete'))) targetSection = sec;
            });
            switchTab('summary');
            if (targetSection) {
                setTimeout(() => {
                    const header = targetSection.querySelector('.w-full');
                    if (header) {
                        header.click();
                        targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }, 300);
            } else {
                // Fallback: search the category name in summary search
                const searchInput = document.getElementById('summary-search');
                if (searchInput) {
                    searchInput.value = cat.split('&')[0].trim();
                    searchInSummary();
                }
            }
        }

        function finishPracticeSession() {
            stopAutoAdvance();
            const total = practiceSessionStats.attempted;
            const correct = practiceSessionStats.correct;
            const wrong = practiceSessionStats.wrong;
            const acc = total > 0 ? Math.round((correct / total) * 100) : 0;
            
            document.getElementById('active-quiz-box').classList.add('hidden');
            document.getElementById('results-analytics-box').classList.remove('hidden');
            
            document.getElementById('final-score-big').innerText = `${correct} / ${total}`;
            
            let feedback = '';
            if (acc >= 90) feedback = "Harika bir performans! TRK102'ye hazırsın.";
            else if (acc >= 70) feedback = "İyi gidiyorsun! Eksiklerini gözden geçirmek için Yanlış Bankası'nı ziyaret et.";
            else if (acc >= 50) feedback = 'Orta seviye. Dil Rehberi ve Modül Özetlerini çalışmanı öneririm.';
            else feedback = "Bu konulara tekrar çalışmalısın. Dil Rehberi'ni baştan sona gözden geçir.";
            
            document.getElementById('letter-grade-badge').innerText = acc >= 90 ? 'AA' : acc >= 70 ? 'BB' : acc >= 50 ? 'CC' : 'FF';
            document.getElementById('final-feedback-text').innerText = `Çözüm Odaklı oturum sonu: ${total} soru, %${acc} başarı. ${feedback}`;
            
            // Replace chart title for practice
            const chartTitle = document.querySelector('#results-analytics-box h4');
            if (chartTitle) chartTitle.textContent = 'Oturum Analizi';
            
            updateGlobalStats();
            window.scrollTo({ top: 0, behavior: 'smooth' });
            if (acc >= 50) fireConfetti();
            showNotification(`🎯 Oturum tamamlandı! %${acc} başarı.`, acc >= 70 ? 'success' : 'amber');
        }

        function toggleSpeechGlobally() {
            ttsEnabled = !ttsEnabled;
            const btn = document.getElementById('btn-tts-global');
            const icon = document.getElementById('tts-icon');
            if (ttsEnabled) {
                btn.classList.add('bg-brand-50', 'text-brand-600', 'border-brand-200');
                showNotification('Sesli Sınav Okuyucu Aktif!', 'success');
                speakText("Sesli sınav okuyucu aktif edildi.");
            } else {
                btn.classList.remove('bg-brand-50', 'text-brand-600', 'border-brand-200');
                stopSpeech();
                showNotification('Sesli Okuyucu Kapatıldı');
            }
        }

        function speakText(text) {
            if (!ttsEnabled || !('speechSynthesis' in window)) return;
            window.speechSynthesis.cancel();
            
            activeUtterance = new SpeechSynthesisUtterance(text);
            activeUtterance.lang = 'tr-TR';
            activeUtterance.rate = 1.05;
            
            activeUtterance.onstart = function() {
                document.getElementById('speech-control-bar').classList.remove('hidden');
            };
            activeUtterance.onend = function() {
                document.getElementById('speech-control-bar').classList.add('hidden');
            };
            activeUtterance.onerror = function() {
                document.getElementById('speech-control-bar').classList.add('hidden');
            };
            
            window.speechSynthesis.speak(activeUtterance);
        }

        function pauseSpeech() {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.pause();
                showNotification('Sesli okuma duraklatıldı');
            }
        }

        function resumeSpeech() {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.resume();
                showNotification('Sesli okuma devam ediyor');
            }
        }

        function stopSpeech() {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                document.getElementById('speech-control-bar').classList.add('hidden');
            }
        }

        function speakCurrentQuestion() {
            if (!('speechSynthesis' in window)) return;
            const q = examQuestions[currentQuestionIndex];
            const cleanText = q.q.replace(/['"()]/g, '');
            const optionsText = q.a.map((opt, i) => `${String.fromCharCode(65 + i)} Şıkkı: ${opt}`).join('. ');
            speakText(`${cleanText}. Seçenekler şunlardır: ${optionsText}`);
        }

        function speakCurrentFlashcard() {
            const card = flashcardsDataset[currentFlashcardIndex];
            speakText(`Kategori: ${card.cat}. Soru kartı: ${card.front}. Cevap kartı: ${card.back}`);
        }

        function speakSummarySection(sectionId) {
            const section = document.getElementById(sectionId);
            if (!section) return;
            const textContent = section.querySelector('.summary-content').innerText;
            const originalTts = ttsEnabled;
            ttsEnabled = true;
            speakText(textContent);
            ttsEnabled = originalTts;
        }

        function setGlobalStudyMode(mode) {
            studyMode = mode;
            document.getElementById('mode-quiz').className = mode === 'quiz' ? 'px-3 py-1.5 rounded-lg transition-all bg-brand-500/20 text-white shadow-sm' : 'px-3 py-1.5 rounded-lg transition-all text-slate-400 hover:text-white';
            document.getElementById('mode-practice').className = mode === 'practice' ? 'px-3 py-1.5 rounded-lg transition-all bg-brand-500/20 text-white shadow-sm' : 'px-3 py-1.5 rounded-lg transition-all text-slate-400 hover:text-white';
            
            stopAutoAdvance();
