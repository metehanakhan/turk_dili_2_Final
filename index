                explanation: "'Yanlış' sözcüğü 'yalnış' değildir. Kökeni 'yanıl-' fiilidir. 'Yanlış' doğru yazılıştır. Aynı şekilde 'yanlışlıkla' şeklinde yazılır."
            },
            {
                pattern: /kalemimide/g,
                replace: "kalemimi de",
                explanation: "'Kalemimi de' ifadesindeki 'de' bağlaçtır ve ayrı yazılmalıdır. 'Benim kalemimi de aldın' şeklinde doğru kullanım sağlanır."
            },
            {
                pattern: /yemekden/g,
                replace: "yemekten",
                explanation: "Sert ünsüzle (k, ç, t, ş, p, h) biten sözcüklere gelen ekler sertleşir: yemek + den → yemekten. Fıstıkçı Şahap kuralı."
            },
            {
                pattern: /bizirada/g,
                replace: "bizleri de",
                explanation: "Çoğul eki almış zamirlere gelen 'de' bağlacı ayrı yazılır: 'bizleri de', 'seni de', 'onları da'."
            },
            {
                pattern: /Bunuda/g,
                replace: "Bunu da",
                explanation: "'Bunu' sözcüğünden sonra gelen 'da/De' bağlacı ayrı yazılır: 'Bunu da yapabildiysen'."
            },
            {
                pattern: /yüzyüze/g,
                replace: "yüz yüze",
                explanation: "İkilemeler ayrı yazılır: 'yüz yüze', 'baş başa', 'diz dize', 'göz göze', 'el ele'. İkilemeyi oluşturan kelimeler arasına boşluk konur."
            },
            {
                pattern: /azalmakda/g,
                replace: "azalmakta",
                explanation: "Sert ünsüz uyumu: 'k' sert ünsüzüyle biten 'azalmak' fiiline gelen 'da' eki 'ta' şeklinde sertleşir: 'azalmakta'."
            },
            {
                pattern: /toplumsal yapıyada/g,
                replace: "toplumsal yapıya da",
                explanation: "'Yapıya' sözcüğüne gelen 'da' bağlacı ayrı yazılır. Ayrıca 'yapıya' yönelme durum eki (-a) almıştır, bağlaç değildir."
            },
            {
                pattern: /Antalyaya/g,
                replace: "Antalya'ya",
                explanation: "Özel isimlere gelen yönelme durum eki kesme işaretiyle ayrılır ve ünsüz yumuşamasına uğrar: Antalya'ya (Antalya + a → Antalya'ya, 'y' kaynaştırma ünsüzü)."
            }
        ];

        function loadLabTemplate(key) {
            const editor = document.getElementById('lab-editor');
            editor.value = labTemplates[key];
            analyzeLabText();
            showNotification(`${key.toUpperCase()} şablonu başarıyla yüklendi!`, "success");
        }

        function clearLabEditor() {
            document.getElementById('lab-editor').value = '';
            analyzeLabText();
            showNotification("Yazım alanı temizlendi.");
        }

        function analyzeLabText() {
            const text = document.getElementById('lab-editor').value;
            const feedbackPanel = document.getElementById('lab-feedback-panel');
            const errorsList = document.getElementById('lab-errors-list');
            const scoreBadge = document.getElementById('lab-score-badge');

            if (!text.trim()) {
                feedbackPanel.classList.add('hidden');
                scoreBadge.classList.add('hidden');
                return;
            }

            feedbackPanel.classList.remove('hidden');
            scoreBadge.classList.remove('hidden');

            errorsList.innerHTML = '';
            let detectedCount = 0;
            let totalPoints = 100;

            grammarRules.forEach(rule => {
                if (rule.pattern.test(text)) {
                    detectedCount++;
                    totalPoints = Math.max(0, totalPoints - 15);

                    const li = document.createElement('div');
                    li.className = 'p-3 bg-accent-rose/10 border-l-4 border-accent-rose rounded-r-xl text-xs sm:text-sm space-y-1';
                    li.innerHTML = `
                        <div class="flex items-center justify-between">
                            <span class="font-extrabold text-accent-rose">Kural İhlali</span>
                            <span class="text-[10px] text-slate-400 font-bold">Öneri: "${rule.replace}"</span>
                        </div>
                        <p class="font-semibold text-slate-400">${rule.explanation}</p>
                    `;
                    errorsList.appendChild(li);
                }
            });

            if (text.toLowerCase().includes("bilgilerinize arz ederim") && text.toLowerCase().includes("imza")) {
                const imzaIndex = text.toLowerCase().indexOf("imza");
                const adresIndex = text.toLowerCase().indexOf("adres");
                if (adresIndex !== -1 && imzaIndex > adresIndex) {
                    detectedCount++;
                    totalPoints = Math.max(0, totalPoints - 10);
                    const li = document.createElement('div');
                    li.className = 'p-3 bg-accent-rose/10 border-l-4 border-accent-rose rounded-r-xl text-xs sm:text-sm space-y-1';
                    li.innerHTML = `
                        <div class="flex items-center justify-between">
                            <span class="font-extrabold text-accent-rose">Dilekçe Format Hatası</span>
                            <span class="text-[10px] text-slate-400 font-bold">Öneri: İmza Sağ Altta Olmalı</span>
                        </div>
                        <p class="font-semibold text-slate-400">Resmi dilekçelerde imza, ad ve soyad daima sağ alt köşede yer almalıdır. Sol alt tarafta adres ve ekler bulunmalıdır.</p>
                    `;
                    errorsList.appendChild(li);
                }
            }

            document.getElementById('lab-score-badge').innerText = `Puan: ${totalPoints}/100`;

            if (detectedCount === 0) {
                errorsList.innerHTML = `
                    <div class="p-4 bg-accent-emerald/10 border-l-4 border-accent-emerald rounded-r-xl text-xs sm:text-sm flex items-center space-x-2">
                        <span class="text-lg">✨</span>
                        <span class="font-bold text-emerald-300">Metinde hiçbir bariz TRK101 veya TRK102 hatası saptanmadı.</span>
                    </div>
                `;
                document.getElementById('lab-score-badge').className = "px-3 py-1 bg-accent-emerald/10 text-accent-emerald rounded-lg text-xs font-black animate-pulse";
            } else {
                document.getElementById('lab-score-badge').className = "px-3 py-1 bg-accent-rose/10 text-accent-rose rounded-lg text-xs font-black";
            }
        }

        function fixLabErrorsAutomatically() {
            let text = document.getElementById('lab-editor').value;
            let fixedCount = 0;

            grammarRules.forEach(rule => {
                if (rule.pattern.test(text)) {
                    text = text.replace(rule.pattern, rule.replace);
                    fixedCount++;
                }
            });

            if (fixedCount > 0) {
                document.getElementById('lab-editor').value = text;
                analyzeLabText();
                showNotification(`Yapay zeka ${fixedCount} yazım hatasını otomatik olarak düzeltti!`, "success");
                speakText("Tüm yazım hataları otomatik olarak başarıyla düzeltildi.");
            } else {
                showNotification("Düzeltilecek bariz bir hata bulunamadı.");
            }
        }

        // ================= BONUS FEATURES =================

        // --- TIMER ---
        let examTimerInterval = null;
        let examTimeLeft = 3600;

        function toggleExamTimer() {
            const timerEl = document.getElementById('exam-timer');
            if (examTimerInterval) {
                clearInterval(examTimerInterval);
                examTimerInterval = null;
                timerEl.classList.add('hidden');
                showNotification('Süreli sınav modu kapatıldı');
                return;
            }
            examTimeLeft = 3600;
            timerEl.classList.remove('hidden');
            timerEl.classList.add('flex');
            timerEl.innerText = '⏱ 60:00';
            showNotification('Süreli sınav modu: 60 dakika!', 'success');
            examTimerInterval = setInterval(() => {
                examTimeLeft--;
                const min = String(Math.floor(examTimeLeft / 60)).padStart(2, '0');
                const sec = String(examTimeLeft % 60).padStart(2, '0');
                timerEl.innerText = `⏱ ${min}:${sec}`;
                if (examTimeLeft <= 300) {
                    timerEl.classList.add('text-accent-rose', 'bg-accent-rose/10');
                }
                if (examTimeLeft <= 0) {
                    clearInterval(examTimerInterval);
                    examTimerInterval = null;
                    showNotification('Süre doldu! Sınav otomatik bitiriliyor...', 'amber');
                    setTimeout(() => finishExamAndShowAnalytics(), 1500);
                }
            }, 1000);
        }

        // --- QUESTION NAVIGATOR ---
        function toggleQuestionNavigator() {
            const nav = document.getElementById('question-navigator');
            nav.classList.toggle('hidden');
            if (!nav.classList.contains('hidden')) {
                renderQuestionNavigator();
            }
        }

        function renderQuestionNavigator() {
            const nav = document.getElementById('question-navigator');
            nav.innerHTML = '';
            examQuestions.forEach((q, idx) => {
                const btn = document.createElement('button');
                let bg = 'bg-slate-700/50 text-slate-300';
                let ring = '';
                if (selectedAnswers[idx] === q.c) {
                    bg = 'bg-accent-emerald/10 text-accent-emerald';
                } else if (selectedAnswers[idx] !== undefined && selectedAnswers[idx] !== q.c) {
                    bg = 'bg-accent-rose/10 text-accent-rose';
                }
                if (idx === currentQuestionIndex) {
                    ring = 'ring-2 ring-brand-500';
                }
                btn.className = `w-8 h-8 rounded-lg text-[10px] font-black ${bg} ${ring} hover:scale-110 transition-all`;
                btn.innerText = idx + 1;
                btn.onclick = () => {
                    currentQuestionIndex = idx;
                    loadQuizQuestion();
                    nav.classList.add('hidden');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                nav.appendChild(btn);
            });
        }

        // --- WRONG ANSWER BANK ---
        let wrongAnswerBank = JSON.parse(localStorage.getItem('wrong_bank_tr102')) || [];

        function getWrongAnswers() {
            wrongAnswerBank = [];
            examQuestions.forEach((q, idx) => {
                if (selectedAnswers[idx] !== undefined && selectedAnswers[idx] !== q.c) {
                    wrongAnswerBank.push({ index: idx, question: q, selected: selectedAnswers[idx] });
                }
            });
            localStorage.setItem('wrong_bank_tr102', JSON.stringify(wrongAnswerBank));
            updateWrongBankStat();
        }

        function updateWrongBankStat() {
            document.getElementById('stat-wrong-count').innerText = wrongAnswerBank.length;
        }

        function openWrongAnswerBank() {
            if (wrongAnswerBank.length === 0) {
                showNotification('Yanlış bankası boş. Soruları çözerek yanlışlarını biriktir!');
                return;
            }
            switchTab('library');
            document.getElementById('library-category-select').value = 'wrong';
            document.getElementById('library-search').value = '';
            onlyShowFavoritesFilter = false;
            document.getElementById('btn-filter-favorites').className = "px-4 py-2 text-[10px] font-bold rounded-xl border border-slate-600 bg-slate-700/50 text-slate-400 hover:text-accent-amber hover:border-accent-amber/30 transition-all flex items-center space-x-1.5";
            renderWrongBankLibrary();
            showNotification(`${wrongAnswerBank.length} yanlış soru bankaya kaydedildi. Gözden geçir!`, 'amber');
        }

        function renderWrongBankLibrary() {
            const container = document.getElementById('library-questions-list');
            container.innerHTML = '';
            if (wrongAnswerBank.length === 0) {
                container.innerHTML = '<div class="p-8 text-center text-slate-400 font-bold text-sm">Henüz yanlış cevaplanmış soru yok. Sınav simülasyonuna başla!</div>';
                return;
            }
            wrongAnswerBank.forEach((item) => {
                const q = item.question;
                const card = document.createElement('div');
                card.className = "premium-card p-5 rounded-2xl border-2 border-accent-rose/30 space-y-4 shadow-sm relative interactive-card";
                let optionsHTML = `<div class="grid grid-cols-1 gap-2 mt-3">`;
                q.a.forEach((opt, idx) => {
                    const isCorrect = idx === q.c;
                    const isSelected = idx === item.selected;
                    let cls = 'bg-slate-700/30 border border-slate-600 text-slate-400';
                    if (isCorrect) cls = 'bg-accent-emerald/10 border border-accent-emerald/20 text-accent-emerald';
                    if (isSelected && !isCorrect) cls = 'bg-accent-rose/10 border border-accent-rose/20 text-accent-rose line-through';
                    optionsHTML += `
                        <div class="p-3 rounded-xl text-[11px] font-semibold ${cls} flex items-start">
                            <span class="mr-2 font-black">${String.fromCharCode(65 + idx)})</span>
                            <span>${opt} ${isSelected && !isCorrect ? '(Senin cevabın)' : ''} ${isCorrect ? '(Doğru)' : ''}</span>
                        </div>
                    `;
                });
                optionsHTML += `</div>`;
                card.innerHTML = `
                    <div class="flex items-center justify-between">
                        <span class="px-2.5 py-1 bg-accent-rose/10 text-accent-rose font-bold text-[9px] rounded-lg uppercase tracking-wider">${q.cat} | #${item.index + 1}</span>
                        <span class="text-[10px] font-bold text-accent-rose">YANLIŞ</span>
                    </div>
                    <h4 class="font-extrabold text-xs sm:text-sm text-slate-200 leading-relaxed whitespace-pre-wrap mt-2">${q.q}</h4>
                    ${optionsHTML}
                    <div class="p-3 bg-brand-500/5 border border-brand-500/10 rounded-xl text-[11px] font-semibold text-slate-300 mt-2 whitespace-pre-wrap">
                        <strong>Detaylı Çözüm:</strong><br>${q.explanation}
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Override library rendering to support wrong bank view
        const origRenderLibrary = renderLibrary;
        renderLibrary = function() {
            if (document.getElementById('library-category-select').value === 'wrong') {
                renderWrongBankLibrary();
                return;
            }
            origRenderLibrary();
        };

        // Override selectQuizAnswer to track wrong answers + show feedback
        const origSelectQuizAnswer = selectQuizAnswer;
        selectQuizAnswer = function(answerIndex) {
            origSelectQuizAnswer(answerIndex);

            // Show feedback
            const q = examQuestions[currentQuestionIndex];
            const isCorrect = answerIndex === q.c;
            const fbContainer = document.getElementById('explanation-container');
            const fbText = document.getElementById('explanation-text');
            const studyLink = document.getElementById('study-link-container');
            if (fbContainer && fbText) {
                fbContainer.classList.remove('hidden', 'feedback-correct', 'feedback-wrong');
                if (isCorrect) {
                    fbContainer.classList.add('feedback-correct');
                    fbText.innerHTML = `✅ <strong>Doğru!</strong> ${q.explanation || ''}`;
                    if (studyLink) studyLink.classList.add('hidden');
                } else {
                    fbContainer.classList.add('feedback-wrong');
                    fbText.innerHTML = `❌ <strong>Yanlış.</strong> Doğru cevap: <strong>${q.a[q.c]}</strong>. ${q.explanation || ''}`;
                    if (studyLink) studyLink.classList.remove('hidden');
                }
            }

            getWrongAnswers();
            updateWrongBankStat();
            renderQuestionNavigator();
            
            if (studyMode === 'practice') {
                startAutoAdvance();
            }
        };

        // Hint system
        window.currentHintIndex = -1;
        function generateHint(q) {
            const catHints = {
                "Paragraf Bilgisi & Kompozisyon": ["Anahtar kelimelere odaklan: paragrafta hangi düşünceyi geliştirme yöntemi kullanılmış?", "Yazarın amacı ne? Betimleme, örneklendirme, tanık gösterme veya istatistik mi?", "Alıntı, örnek, tasvir veya sayısal veri var mı?"],
                "Sözlü Kompozisyon & Konuşma Türleri": ["Hangi sözlü anlatım türünün özelliklerini taşıyor? Münazara, forum, sempozyum veya hitabet?", "Dinleyici katılımı var mı? Tartışma tek yönlü mü?"],
                "Edebî Türler (Sanatsal)": ["Hangi edebî türün özellikleri var? Destan, hikaye, roman, tiyatro, masal?", "Dönemine dikkat et: İslamiyet öncesi/sonrası, Tanzimat, Servet-i Fünun?"],
                "Edebî Türler (Öğretici)": ["Öğretici metin türlerinden hangisi? Makale, deneme, eleştiri, fıkra?", "Yazarın üslubu nesnel mi öznel mi?"],
                "İletişim ve Sözlü Anlatım": ["İletişim ögelerinden hangisi? Kaynak, mesaj, kanal, alıcı, dönüt?", "Engel türlerine dikkat et: psikolojik, fiziksel, kültürel?"],
                "Dil Bilgisi / Çatı": ["Fiil çatısı eklerine bak: -l, -n, -ş, -r, -t, -tır?", "Etken/edilgen mi, geçişli/geçişsiz mi?"],
                "Dil Bilgisi": ["Yapım eki mi çekim eki mi? İsimden fiil mi fiilden isim mi?", "Sözcük türüne dikkat et: isim, sıfat, zamir, fiil?"],
                "Resmî Yazışmalar": ["Hangi resmî yazışma türü? Dilekçe, tutanak, rapor, öz geçmiş?", "Format ve imza yerlerine dikkat et."],
                "Yazım Kuralları": ["Yazım kuralına odaklan: bitişik/ayrı, büyük harf, sayılar, kısaltmalar?", "-ki eki, -de eki, 'şey' yazımını kontrol et."]
            };
            const hints = catHints[q.cat] || ["Soruyu dikkatlice tekrar oku. Anahtar kavramları belirle.", "Şıkları eleyerek düşün. Hangi şık diğerlerinden farklı?"];
            return hints[Math.floor(Math.random() * hints.length)];
        }

        function toggleHint() {
            const hintBox = document.getElementById('hint-box');
            const hintText = document.getElementById('hint-text');
            const btn = document.getElementById('btn-hint');
            if (!hintBox || !hintText) return;
            if (hintBox.classList.contains('active')) {
                hintBox.classList.remove('active');
                if (btn) btn.querySelector('span').textContent = 'İpucu Göster';
            } else {
                const q = examQuestions[currentQuestionIndex];
                if (q) hintText.textContent = generateHint(q);
                hintBox.classList.add('active');
                if (btn) btn.querySelector('span').textContent = 'İpucu Gizle';
            }
        }

        // Mini Exam Mode
        function openMiniExam() {
            const total = questionsDataset.length;
            const count = 10;
            const shuffled = [...questionsDataset].sort(() => Math.random() - 0.5);
            const selected = shuffled.slice(0, count);

            examQuestions = selected;
            currentQuestionIndex = 0;
            selectedAnswers = {};

            switchTab('quiz-engine');

            const timerEl = document.getElementById('exam-timer');
            if (timerEl) timerEl.classList.remove('hidden');

            const finishBtn = document.getElementById('engine-finish-btn');
            if (finishBtn) finishBtn.classList.remove('hidden');

            const counter = document.getElementById('engine-question-counter');
            if (counter) counter.textContent = `Soru: 1 / ${count} (Mini Sınav)`;

            const category = document.getElementById('engine-question-category');
            if (category) category.textContent = '🎯 Mini Sınav';

            // Short timer (10 minutes)
            let timeLeft = 10 * 60;
            if (window.examTimerInterval) clearInterval(window.examTimerInterval);
            if (timerEl) timerEl.textContent = `⏱ ${Math.floor(timeLeft/60)}:${String(timeLeft%60).padStart(2,'0')}`;

            window.examTimerInterval = setInterval(() => {
                timeLeft--;
                if (timerEl) timerEl.textContent = `⏱ ${Math.floor(timeLeft/60)}:${String(timeLeft%60).padStart(2,'0')}`;
                if (timeLeft <= 60 && timerEl) timerEl.classList.add('text-accent-rose');
                if (timeLeft <= 0) {
                    clearInterval(window.examTimerInterval);
                    finishExamAndShowAnalytics();
                }
            }, 1000);

            loadQuizQuestion();

            // Show toast
            const tc = document.getElementById('toast-container');
            if (tc) {
                const t = document.createElement('div');
                t.className = 'pointer-events-auto bg-slate-800 text-slate-200 px-4 py-3 rounded-2xl shadow-2xl border border-brand-500/20 text-xs font-bold animate-slide-up';
                t.innerHTML = '🎯 Mini Sınav başladı! 10 soru, 10 dakika.';
                tc.appendChild(t);
                setTimeout(() => t.remove(), 3000);
            }
        }

        // Category-based Mini Test Feature
        function startCategoryMiniTest(category) {
            let pool;
            if (category === 'all') {
                pool = [...questionsDataset].sort(() => Math.random() - 0.5).slice(0, 5);
            } else {
                pool = questionsDataset.filter(q => q.cat === category);
                if (pool.length < 3) {
                    showNotification('Bu kategoride yeterli soru yok!', 'amber');
                    return;
                }
                pool = pool.sort(() => Math.random() - 0.5).slice(0, Math.min(5, pool.length));
            }

            examQuestions = pool;
            currentQuestionIndex = 0;
            selectedAnswers = {};

            switchTab('quiz-engine');

            const timerEl = document.getElementById('exam-timer');
            if (timerEl) timerEl.classList.remove('hidden');

            const finishBtn = document.getElementById('engine-finish-btn');
            if (finishBtn) finishBtn.classList.remove('hidden');

            const counter = document.getElementById('engine-question-counter');
            if (counter) counter.textContent = `Soru: 1 / ${pool.length} (Konu Testi)`;

            const categoryEl = document.getElementById('engine-question-category');
            if (categoryEl) categoryEl.textContent = category === 'all' ? '🎯 Karma Test' : `📚 ${category}`;

            let timeLeft = 5 * 60;
            if (window.examTimerInterval) clearInterval(window.examTimerInterval);
            if (timerEl) timerEl.textContent = `⏱ ${Math.floor(timeLeft/60)}:${String(timeLeft%60).padStart(2,'0')}`;

            window.examTimerInterval = setInterval(() => {
                timeLeft--;
                if (timerEl) timerEl.textContent = `⏱ ${Math.floor(timeLeft/60)}:${String(timeLeft%60).padStart(2,'0')}`;
                if (timeLeft <= 60 && timerEl) timerEl.classList.add('text-accent-rose');
                if (timeLeft <= 0) {
                    clearInterval(window.examTimerInterval);
                    finishExamAndShowAnalytics();
                }
            }, 1000);

            loadQuizQuestion();

            showNotification(`🎯 ${category === 'all' ? 'Karma' : category} testi başladı! ${pool.length} soru, 5 dakika.`, 'success');
        }

        function populateCategoryTestButtons() {
            const container = document.getElementById('category-test-buttons');
            if (!container) return;
            const cats = [...new Set(questionsDataset.map(q => q.cat))];
            cats.forEach((cat) => {
                const btn = document.createElement('button');
                btn.onclick = () => startCategoryMiniTest(cat);
                btn.className = 'cat-test-btn px-3 py-2 rounded-xl text-[10px] font-bold transition-all border border-brand-500/20 text-brand-300 hover:bg-brand-500/10 text-left leading-tight';
                btn.textContent = cat.split('&')[0].trim();
                container.appendChild(btn);
            });
        }
        const origInitApp = initApp;
        initApp = function() {
            examQuestions = [...questionsDataset];
            renderFlashcard();
            renderLibrary();
            updateGlobalStats();
            updateWrongBankStat();
            populateCategoryTestButtons();
            updateModeBadge();
            updatePracticeStatsUI();
            if (!('speechSynthesis' in window)) {
                document.getElementById('btn-tts-global').style.display = 'none';
                document.getElementById('btn-tts-speak').style.display = 'none';
            }
        };

        // Add timed mode button to nav
        setTimeout(() => {
            const modeBtns = document.querySelector('#mode-quiz').parentElement;
            const timerBtn = document.createElement('button');
            timerBtn.onclick = toggleExamTimer;
            timerBtn.className = "px-3 py-1.5 rounded-lg transition-all text-slate-400 hover:text-white";
            timerBtn.id = "mode-timer";
            timerBtn.innerText = "⏱ Süreli";
            if (modeBtns) modeBtns.appendChild(timerBtn);

            // Add wrong bank option to library filter
            const catSelect = document.getElementById('library-category-select');
            if (catSelect) {
                const opt = document.createElement('option');
                opt.value = 'wrong';
                opt.innerText = 'Yanlış Bankası';
                catSelect.appendChild(opt);
            }
        }, 100);
    </script>
